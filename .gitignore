# Dependencies
node_modules/
.npm-cache/
# Build output
dist/

# Local data & auth
store/
data/
logs/

# Groups - only track base structure and specific CLAUDE.md files
groups/*
!groups/main/
!groups/global/
groups/main/*
groups/global/*
!groups/main/CLAUDE.md
!groups/global/CLAUDE.md

# Secrets
*.keys.json
.env
.env.bak
.env.backup*
.env.*.bak
.env.local
.env.preserved*
*.session
*.session-journal
# Telethon recovery creds are kept out of the repo entirely (~/.config/nanoclaw-recovery/),
# but guard against a misplaced file here just in case.
scripts/uncaged-recovery/*.session*
scripts/uncaged-recovery/uncaged_messages.jsonl

# Temp files
.tmp-*
insurance-scraper/*.log

# OS
.DS_Store

# IDE
.idea/
.vscode/

# Skills system (local per-installation state)
.nanoclaw/

agents-sdk-docs
.notion-token
__pycache__/
*.pyc
