# Telegram Webhook Configuration Example
# Copy these settings to your .env file and customize as needed

# Enable webhook mode (set to 'true' for webhooks, 'false' or omit for polling)
WEBHOOK_ENABLED=true

# Webhook server port (default: 3002)
WEBHOOK_PORT=3002

# Your public domain for webhook URL (REQUIRED for webhook mode)
# This should be your server's public domain/IP where Telegram can reach your webhook
WEBHOOK_DOMAIN=your-domain.com

# Webhook endpoint path (default: /webhook)
WEBHOOK_PATH=/webhook

# Secret token for webhook security (recommended)
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET_TOKEN=your-secret-token-here

# HTTP/3 support (experimental, default: false)
HTTP3_ENABLED=false

# Maximum concurrent webhook connections (default: 100)
WEBHOOK_MAX_CONNECTIONS=100

# Rate limiting: requests per minute per IP (default: 1000)
WEBHOOK_RATE_LIMIT=1000

# Your existing Telegram bot token (REQUIRED)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here