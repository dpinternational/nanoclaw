# Supabase credentials (same as on Mac)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key

# Scraper settings
HEADLESS=true
INTER_STATE_SLEEP=3600
WORKER_ID=scraper-single
RUNNING_STALE_MINUTES=120
ENABLE_MONTHLY_RESET=false
CLAIM_RETRY_SLEEP=2

# Optional: proxy for when NAIC blocks the IP
# PROXY_URL=socks5://user:pass@host:port
