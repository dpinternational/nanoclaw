# Copy this file to .env.worker1 / .env.worker2 / .env.worker3 ...
# and set a distinct proxy session per worker.

SUPABASE_URL=https://snsoophwazxusonudtkv.supabase.co
SUPABASE_KEY=YOUR_SUPABASE_KEY

HEADLESS=true
INTER_STATE_SLEEP=300
RUNNING_STALE_MINUTES=120
ENABLE_MONTHLY_RESET=false

# IMPORTANT: use a distinct proxy session (or distinct proxy endpoint) per worker.
# Example patterns below (adjust to your IPRoyal format):
# PROXY_URL=http://username-session-w1:password@geo.iproyal.com:12321
# PROXY_URL=http://username-session-w2:password@geo.iproyal.com:12321
# If using IP whitelist mode without auth, use distinct proxy endpoints/ports where possible.
PROXY_URL=http://YOUR_PROXY_USER:YOUR_PROXY_PASS@geo.iproyal.com:12321
